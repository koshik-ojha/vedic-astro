# Backend environment variables

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=vedic_astro_bot

# Or use MongoDB Atlas (cloud):
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Legacy database URL (if you use PostgreSQL instead)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=change-me

# App Configuration
APP_BASE_URL=http://localhost:8000

# JWT Configuration
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRE_MINUTES=10080

# WhatsApp Configuration (Twilio) - Required for contact form
# Get your credentials from https://www.twilio.com/console
# Sign up at: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACe3d721a5f012c25cb27a8040bcf37608
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886  # Your Twilio WhatsApp sandbox number
RECIPIENT_WHATSAPP_NUMBER=+918320709710  # Your WhatsApp number to receive contact form messages

# Alternative: Webhook for WhatsApp (if not using Twilio)
# You can use services like Make.com, Zapier, or CallMeBot
# WHATSAPP_WEBHOOK_URL=https://your-webhook-url.com/webhook

# Optional: If you later integrate Swiss Ephemeris files path
# EPHE_PATH=/app/ephe
